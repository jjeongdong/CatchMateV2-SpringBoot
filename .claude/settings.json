{
  "permissions": {
    "allow": [
      "Bash(./gradlew compileJava*)",
      "Bash(./gradlew compileTestJava*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(./deploy.sh:*)",
      "Bash(./deploy-local.sh:*)",
      "Read(./src/main/resources/firebase-adminsdk.json)",
      "Read(./src/main/resources/application-local.yml)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-java-rules.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-java-architecture.py\""
          }
        ]
      }
    ]
  }
}
